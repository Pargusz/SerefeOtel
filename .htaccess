# Şerefe Otel - Clean URL Configuration for Apache (cPanel)

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect .html to clean URL (optional, for existing links)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
    RewriteRule ^ %1 [R=301,L]

    # Internal rewrite to .html if file exists
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # Handle Directory Index (e.g., /about/ -> /about/index.html)
    DirectoryIndex index.html
</IfModule>

# Security - Disable Directory Browsing
Options -Indexes

# Cache Policy for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
